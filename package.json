{
  "name": "ccmux",
  "version": "0.1.0",
  "description": "Persistent, self-healing Claude Code tmux sessions with deterministic resume — across a fleet of machines.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ccmux": "./dist/ccmux"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "tui": "bun run src/cli.ts",
    "tui:hot": "bun --hot src/cli.ts",
    "smoke": "bash scripts/tui-smoke.sh",
    "stage": "bun scripts/release.ts --stage",
    "release": "bun scripts/release.ts",
    "release:publish": "bun scripts/release.ts --publish",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  }
}
