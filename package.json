{
  "name": "ccmux",
  "version": "0.1.12",
  "description": "Persistent, self-healing Claude Code tmux sessions with deterministic resume — across a fleet of machines.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ccmux": "./dist/ccmux"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "bun run src/cli.ts",
    "tui": "bun run src/cli.ts",
    "tui:hot": "bun --hot src/cli.ts",
    "smoke": "bash scripts/tui-smoke.sh",
    "check": "tsc --noEmit && bun test",
    "stage": "bun scripts/release.ts --stage",
    "release": "bun scripts/release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "packageManager": "bun@1.3.14"
}
