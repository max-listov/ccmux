#!/usr/bin/env bash
# ccmux — Cloud Code MUX
# Persistent, self-healing tmux sessions for Claude Code, with deterministic resume.
# One script. One daemon. No build, no deps beyond bash + tmux. https://github.com/…
set -u

VERSION=1.4.1

# ── Config ──────────────────────────────────────────────────────────────────
# One artifact, many machines: everything machine-specific is overridable via
# ~/.config/ccmux/config (sourced) or env. Sensible per-OS defaults + autodetect
# so a fresh box needs ~zero config. Sessions live in a separate data file so
# `ccmux new` never edits this script (code and data stay separated).
CONFIG_FILE="${CCMUX_CONFIG:-$HOME/.config/ccmux/config}"
# shellcheck disable=SC1090
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"

_have() { command -v "$1" 2>/dev/null; }
CLAUDE_BIN="${CLAUDE_BIN:-$(_have claude || echo "$HOME/.local/bin/claude")}"
TMUX_BIN="${TMUX_BIN:-$(_have tmux || echo /opt/homebrew/bin/tmux)}"
PROJECTS_DIR="${PROJECTS_DIR:-$HOME/.claude/projects}"
SESSIONS_FILE="${CCMUX_SESSIONS:-$HOME/.ccmux-sessions}"
RC_PREFIX="${RC_PREFIX:-local}"          # Remote-Control name prefix: local|dev|prod
PERMISSION_MODE="${PERMISSION_MODE:-auto}"
ENSURE_INTERVAL="${ENSURE_INTERVAL:-30}" # daemon heal period (seconds)
BOOT_LABEL="${BOOT_LABEL:-ccmux}"        # systemd unit / launchd label — same name everywhere
LOG_FILE="${CCMUX_LOG:-$HOME/.ccmux.log}"

# Absolute, symlink-friendly path to this script (mac has no `readlink -f`).
SELF="$(cd "$(dirname "$0")" 2>/dev/null && pwd)/$(basename "$0")"

# ── tmux helpers ────────────────────────────────────────────────────────────
# Plain default tmux socket — so `tmux ls` / `tmux attach -t <name>` work exactly as a
# user expects, no `-L` needed. ccmux is the sole owner of the default socket on the box.
tmux_c() { "$TMUX_BIN" "$@"; }
# EXACT match (=) is critical: names share prefixes (cc-api vs cc-api-v2);
# without '=' tmux prefix-matches and silently hits the wrong session.
tgt()  { printf '=%s' "$1"; }
pane() { printf '=%s:0.0' "$1"; }        # explicit pane; '=NAME' alone won't resolve
# RC name shown in Claude's Remote Control, so a phone/desktop client can tell
# which box a session lives on: cc-api -> prod-api.
rc_name() { printf '%s-%s' "$RC_PREFIX" "${1#cc-}"; }
log() { printf '%s %s\n' "$(date -u +%FT%TZ)" "$*" >> "$LOG_FILE" 2>/dev/null; }

# ── JSON helpers ────────────────────────────────────────────────────────────
# Keep machine-readable output in this script so callers don't scrape the human table.
# No jq dependency here: jq remains optional for context-size extraction only.
json_escape() {
  awk 'BEGIN{ORS=""}
    {
      if (NR > 1) printf "\\n"
      gsub(/\\/,"\\\\")
      gsub(/"/,"\\\"")
      gsub(/\t/,"\\t")
      gsub(/\r/,"\\r")
      gsub(/\n/,"\\n")
      printf "%s", $0
    }'
}
json_string() { printf '"%s"' "$(printf '%s' "$1" | json_escape)"; }
json_nullable_string() { [ -n "${1:-}" ] && [ "$1" != "-" ] && json_string "$1" || printf 'null'; }
json_nullable_number() { [ -n "${1:-}" ] && printf '%s' "$1" || printf 'null'; }
json_bool() { [ "${1:-}" = 1 ] && printf 'true' || printf 'false'; }

json_null() { printf 'null'; }

tok_num() { # 850.0k -> 850000, 1.0M -> 1000000; empty on unknown
  awk -v v="$1" 'BEGIN{
    if (v == "" || v == "-") exit
    unit = substr(v, length(v), 1)
    n = v
    mult = 1
    if (unit == "k" || unit == "K") { mult = 1000; n = substr(v, 1, length(v)-1) }
    else if (unit == "m" || unit == "M") { mult = 1000000; n = substr(v, 1, length(v)-1) }
    else if (unit == "g" || unit == "G") { mult = 1000000000; n = substr(v, 1, length(v)-1) }
    if (n !~ /^[0-9]+([.][0-9]+)?$/) exit
    printf "%.0f", n * mult
  }'
}

context_json() { # $1=context text ("850.0k/1.0M 85%" | "40k" | "-")
  local ctx="$1" pair used_label limit_label percent_label used_tokens limit_tokens percent
  if [ -z "$ctx" ] || [ "$ctx" = "-" ]; then
    printf '{"text":null,"usedTokens":null,"limitTokens":null,"percent":null}'
    return
  fi
  if [[ "$ctx" == */* ]]; then
    pair="${ctx%% *}"
    used_label="${pair%%/*}"
    limit_label="${pair#*/}"
    percent_label="${ctx##* }"
    [ "$percent_label" != "$ctx" ] && percent="${percent_label%%%}"
    used_tokens="$(tok_num "$used_label")"
    limit_tokens="$(tok_num "$limit_label")"
  else
    used_label="$ctx"
    used_tokens="$(tok_num "$used_label")"
  fi
  printf '{"text":'
  json_string "$ctx"
  printf ',"usedTokens":'
  json_nullable_number "$used_tokens"
  printf ',"limitTokens":'
  json_nullable_number "$limit_tokens"
  printf ',"percent":'
  json_nullable_number "$percent"
  printf '}'
}

# ── Sessions data (name|dir|uuid) ───────────────────────────────────────────
# Read FRESH every call — the daemon must see `ccmux new` immediately (the bug a
# read-once `mapfile` would cause). uuid pins the conversation so resume is
# deterministic even for two sessions in the same directory.
_rows() { grep -vE '^[[:space:]]*(#|$)' "$SESSIONS_FILE" 2>/dev/null; }
session_names() { _rows | cut -d'|' -f1; }
session_field() { # $1=name $2=field(2=dir,3=uuid) -> value, nonzero if missing
  local out
  out="$(_rows | awk -F'|' -v n="$1" -v i="$2" '$1==n{print $i; f=1} END{exit !f}')" || return 1
  printf '%s' "$out"
}
session_dir()  { session_field "$1" 2; }
session_uuid() { session_field "$1" 3; }
# Claude encodes the REALPATH of the dir (symlinks resolved: /tmp→/private/tmp on
# mac, network mounts, any symlinked project dir or home). Encoding the raw path would miss
# the jsonl and wrongly fall back to --session-id ("already in use"). `pwd -P` is
# the portable realpath; a not-yet-existing dir falls back to the raw path.
real_dir() { (cd "$1" 2>/dev/null && pwd -P) || printf '%s' "$1"; }
# Claude replaces EVERY non-alphanumeric char (/, ., _, space, …) with '-', not just '/'.
# Verified empirically: /Users/x/cc.dot_test -> -Users-x-cc-dot-test. Replacing only '/'
# would miss the jsonl for any dir containing a '.' or '_' and silently break resume.
hist_file() { printf '%s/%s/%s.jsonl' "$PROJECTS_DIR" "$(real_dir "$1" | sed 's#[^a-zA-Z0-9]#-#g')" "$2"; }

humanize() { # seconds -> 45s | 3m | 2h10m | 5d3h | —
  local s="$1" d h m
  [ "$s" -le 0 ] 2>/dev/null && { printf '—'; return; }
  d=$((s/86400)); h=$(((s%86400)/3600)); m=$(((s%3600)/60))
  if   [ "$d" -gt 0 ]; then [ "$h" -gt 0 ] && printf '%dd%dh' "$d" "$h" || printf '%dd' "$d"
  elif [ "$h" -gt 0 ]; then [ "$m" -gt 0 ] && printf '%dh%dm' "$h" "$m" || printf '%dh' "$h"
  elif [ "$m" -gt 0 ]; then printf '%dm' "$m"
  else printf '%ds' "$s"; fi
}

# Model + context% + working/idle, scraped straight from what claude renders in the
# pane (the model banner / statusline + the working-spinner). One read, no jq/jsonl.
# Prints TAB-separated "model<TAB>ctx<TAB>state"; any field claude doesn't surface
# stays '-' (we never invent a context window).
pane_status() { # $1=name
  local p model ctx state
  p="$(tmux_c capture-pane -t "$(pane "$1")" -p 2>/dev/null | tail -n 30)"
  if printf '%s' "$p" | grep -qE 'esc to interrupt|… \([0-9]+m? ?[0-9]*s ·'; then state=working; else state=idle; fi
  model="$(printf '%s' "$p" | grep -oE '(Opus|Sonnet|Haiku) [0-9.]+' | head -1)"
  ctx="$(printf '%s' "$p" | grep -oE '[0-9.]+[kKMG]/[0-9.]+[kKMG] +[0-9]+%' | head -1)"
  printf '%s\t%s\t%s' "${model:--}" "${ctx:--}" "$state"
}

fmt_tok() { awk -v t="$1" 'BEGIN{ if(t>=1e6)printf"%.1fM",t/1e6; else if(t>=1000)printf"%dk",t/1000; else printf"%d",t }'; }

# Context tokens USED — from the transcript, so it works with NO statusline (universal).
# The window/% only exists in claude's live statusline; without it we still show size.
# Needs jq; prints the number or nothing.
session_used() { # $1=dir $2=uuid
  local jf; jf="$(hist_file "$1" "$2")"; [ -f "$jf" ] || return 1
  tail -n 400 "$jf" 2>/dev/null | jq -r 'select(.message.role=="assistant" and .message.usage)
    | (.message.usage.input_tokens//0)+(.message.usage.cache_read_input_tokens//0)
    +(.message.usage.cache_creation_input_tokens//0)' 2>/dev/null | tail -1
}

file_mtime_ms() { # $1=file -> unix ms, empty if unavailable
  local seconds
  case "$(uname)" in
    Darwin) seconds="$(stat -f %m "$1" 2>/dev/null || true)" ;;
    *)      seconds="$(stat -c %Y "$1" 2>/dev/null || true)" ;;
  esac
  [ -n "$seconds" ] && printf '%s000' "$seconds"
}

transcript_messages_json() { # $1=jsonl $2=start_line $3=text_limit
  local file="$1" start="${2:-1}" text_limit="${3:-4000}"
  awk -v start="$start" 'NR>=start { printf "%d\t%s\n", NR, $0 }' "$file" 2>/dev/null \
    | jq -R -s -c --argjson textLimit "$text_limit" '
      def clip($limit):
        if . == null then null
        else tostring | if length > $limit then .[0:$limit] + "…" else . end
        end;
      def as_text:
        if . == null then null
        elif type == "string" then .
        else tojson
        end;
      def content_items($entry):
        ($entry.message.content // null) as $content
        | if ($content | type) == "array" then $content
          elif ($content | type) == "string" then [{type:"text", text:$content}]
          else []
          end;
      def role_for($entry; $item):
        if ($item.type // "") == "tool_result" then "tool"
        elif ($entry.message.role // "") == "user" then "user"
        elif ($entry.message.role // "") == "assistant" then "assistant"
        elif ($entry.message.role // "") == "system" then "system"
        elif ($entry.type // "") == "user" then "user"
        elif ($entry.type // "") == "assistant" then "assistant"
        elif ($entry.type // "") == "system" then "system"
        else "unknown"
        end;
      def kind_for($item):
        if ($item.type // "") == "text" then "message"
        elif ($item.type // "") == "tool_use" then "tool_call"
        elif ($item.type // "") == "tool_result" then "tool_result"
        elif ($item.type // "") == "thinking" then "thinking"
        elif ($item.type // "") == "" then "unknown"
        else "event"
        end;
      def text_for($item):
        if ($item.type // "") == "text" then ($item.text // "")
        elif ($item.type // "") == "tool_use" then
          ($item.input.description // $item.input.command // $item.input.file_path // ($item.input | as_text) // $item.name // "")
        elif ($item.type // "") == "tool_result" then ($item.content | as_text)
        elif ($item.type // "") == "thinking" then ($item.thinking // "")
        else ($item | as_text)
        end;
      [
        split("\n")[]
        | select(length > 0)
        | (capture("^(?<seq>[0-9]+)\t(?<raw>.*)$")? // empty) as $line
        | ($line.seq | tonumber) as $seq
        | ($line.raw | fromjson? // empty) as $entry
        | (content_items($entry) | to_entries[]) as $wrapped
        | ($wrapped.value) as $item
        | (kind_for($item)) as $kind
        | (text_for($item) | clip($textLimit)) as $text
        | select($kind == "tool_call" or ($text != null and $text != ""))
        | {
            id: (($entry.uuid // ($seq|tostring)) + ":" + (($wrapped.key|tostring))),
            seq: $seq,
            createdAt: ($entry.timestamp // null),
            role: role_for($entry; $item),
            kind: $kind,
            text: $text,
            title: (if $kind == "tool_call" then ($item.name // "tool")
                    elif $kind == "tool_result" then "tool result"
                    else null end),
            toolName: (if $kind == "tool_call" then ($item.name // null) else null end),
            toolCallId: ($item.id // $item.tool_use_id // null),
            status: (if ($item.is_error // false) then "error" else null end),
            rawType: ($item.type // $entry.type // null)
          }
      ]' 2>/dev/null || printf '[]'
}

last_transcript_message_json() { # $1=dir $2=uuid
  _have jq >/dev/null || { json_null; return; }
  local dir="$1" uuid="$2" jf total start messages
  jf="$(hist_file "$dir" "$uuid")"
  [ -f "$jf" ] || { json_null; return; }
  total="$(wc -l < "$jf" 2>/dev/null | tr -d '[:space:]')"
  [ "${total:-0}" -gt 0 ] 2>/dev/null || { json_null; return; }
  start=$(( total > 120 ? total - 119 : 1 ))
  messages="$(transcript_messages_json "$jf" "$start" 280)"
  printf '%s' "$messages" | jq -c 'last // null' 2>/dev/null || json_null
}

# Refuse to stop/rm the session you're calling from (an agent shouldn't kill its
# own conversation). CCMUX_SESSION is exported into each session by cmd_run.
refuse_self() { # $1=verb $2=name $3=force
  if [ "${3:-}" != "--force" ] && [ -n "${CCMUX_SESSION:-}" ] && [ "$2" = "$CCMUX_SESSION" ]; then
    echo "refusing to $1 '$2': you are calling from inside it. pass --force to override."
    return 0
  fi
  return 1
}

# ── Injected system prompt ──────────────────────────────────────────────────
# Lets the in-session Claude manage its siblings through ccmux — drivable from
# Remote Control / Telegram in any language.
build_prompt() { # $1=name
  cat <<PROMPT
You are running inside tmux session '$1', managed by ccmux ($SELF).
Manage Claude sessions by running ccmux (always the absolute path above):
- "list sessions"                      -> $SELF list
- "create NAME in DIR" / "new session" -> $SELF new NAME DIR
- "restart this" / "restart NAME"      -> $SELF restart NAME [--then "<note>"]   (this session: $1; --then pings you back once the session is ready again)
- "stop NAME" / "start NAME" / "remove NAME" -> $SELF stop|start|rm NAME
- "compact NAME" / slash to a session  -> $SELF send NAME '/compact'
- "send /model opus to this"           -> $SELF send $1 '/model opus'
Rules:
- Always print command output verbatim — Remote Control users cannot see tool output.
- Use ccmux, not raw tmux/ls, for session management (avoids permission prompts).
- These triggers work in any language; infer intent.
PROMPT
}

# ── Launch loop (runs inside the tmux session) ──────────────────────────────
cmd_run() { # $1=name
  local name="$1" dir uuid prompt
  dir="$(session_dir "$name")"  || { echo "unknown session: $name"; exit 1; }
  uuid="$(session_uuid "$name")"
  cd "$dir" || exit 1
  export CCMUX_SESSION="$name"               # self-guard marker, inherited by claude
  unset CLAUDECODE CLAUDE_CODE_ENTRYPOINT     # env hygiene: don't confuse a nested claude
  # Boot daemons start with a minimal PATH. Re-derive the user's real login-shell PATH
  # so the session resolves bun/node, statusline scripts and hooks exactly as a normal
  # terminal launch (e.g. a statusLine `bun …` script needs ~/.bun/bin). Universal — we
  # read $SHELL's PATH instead of hardcoding any tool dir; sane fallback otherwise.
  local ush login_path
  ush="${SHELL:-}"; [ -x "$ush" ] || ush="$(command -v zsh || command -v bash || echo /bin/sh)"
  # fish exposes $PATH as a space-separated list; ask it to colon-join. POSIX shells
  # print it as-is. (PROD runs fish — without this the derived PATH is garbage.)
  case "$ush" in
    *fish) login_path="$("$ush" -lc 'string join : $PATH' 2>/dev/null)" ;;
    *)     login_path="$("$ush" -lc 'printf %s "$PATH"' 2>/dev/null)" ;;
  esac
  export PATH="$(dirname "$SELF"):$(dirname "$CLAUDE_BIN"):$(dirname "$TMUX_BIN"):${login_path:+$login_path:}/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin${PATH:+:$PATH}"
  local backoff=2 fastfails=0 fork=0 started elapsed
  while true; do
    prompt="$(build_prompt "$name")"
    # resume the pinned conversation if its transcript exists, else create it at this uuid.
    local -a resume
    if [ -f "$(hist_file "$dir" "$uuid")" ]; then resume=(--resume "$uuid"); else resume=(--session-id "$uuid"); fi
    [ "$fork" = 1 ] && { resume+=(--fork-session); fork=0; }   # one-shot wedge recovery
    started="$(date +%s)"
    "$CLAUDE_BIN" "${resume[@]}" -n "$(rc_name "$name")" \
      --permission-mode "$PERMISSION_MODE" --append-system-prompt "$prompt"
    # Relaunch with backoff judged by ELAPSED TIME, not exit code — claude exits 0 even
    # on a `--session-id already in use` error. A healthy long run resets to 2s; a fast
    # death (bad config, no credits) backs off 2s→60s instead of hot-looping. After 3
    # fast deaths, try once with --fork-session to recover a wedged conversation.
    elapsed=$(( $(date +%s) - started ))
    if [ "$elapsed" -lt 5 ]; then
      fastfails=$((fastfails + 1))
      backoff=$(( backoff * 2 > 60 ? 60 : backoff * 2 ))
      log "relaunch $name: fast exit ${elapsed}s (fail #$fastfails) backoff ${backoff}s"
      [ "$fastfails" -ge 3 ] && { fork=1; fastfails=0; log "relaunch $name: --fork-session recovery"; }
    else
      backoff=2; fastfails=0
    fi
    sleep "$backoff"
  done
}

# ── Session control ─────────────────────────────────────────────────────────
cmd_start() { # $1=name
  local name="$1" dir t
  dir="$(session_dir "$name")" || { echo "unknown session: $name"; return 1; }
  t="$(tgt "$name")"
  tmux_c has-session -t "$t" 2>/dev/null && { echo "$name already running"; return 0; }
  tmux_c new-session -d -s "$name" -c "$dir" "$SELF" _run "$name"
  # Lock the window name so Claude's escape codes can't rename it and break the
  # =NAME exact-match invariant; then quality-of-life pane options.
  tmux_c set-option   -t "$t" automatic-rename off  2>/dev/null
  tmux_c set-option   -t "$t" allow-rename off      2>/dev/null
  tmux_c set-option   -t "$t" mouse on              2>/dev/null
  tmux_c set-option   -t "$t" history-limit 50000   2>/dev/null
  tmux_c set-option -p -t "$(pane "$name")" allow-passthrough on 2>/dev/null
  echo "started $name ($(rc_name "$name"))"
}

cmd_stop() { # $1=name [$2=--force]
  local name="$1"
  refuse_self stop "$name" "${2:-}" && return 1
  tmux_c kill-session -t "$(tgt "$name")" 2>/dev/null && echo "stopped $name" || echo "$name not running"
}

# Wait until a (re)started session is ready for input: claude's banner is up (model
# surfaced) AND it's idle (no working-spinner). Gated on real pane state, not a blind
# sleep, so a wake-note never lands in a half-loaded pane. Two consecutive idle reads
# guard against a transient idle between load frames. Returns nonzero on timeout.
wait_ready() { # $1=name [$2=timeout_s]
  local name="$1" deadline model state ok=0
  deadline=$(( $(date +%s) + ${2:-120} ))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    IFS=$'\t' read -r model _ state < <(pane_status "$name")
    if [ "$model" != '-' ] && [ "$state" = idle ]; then
      ok=$((ok + 1)); [ "$ok" -ge 2 ] && return 0
    else ok=0; fi
    sleep 2
  done
  return 1
}

# Internal: relaunch a session, then (optionally) deliver a wake-note once it's ready.
# Runs detached (see cmd_restart) so it outlives the session that triggered the restart —
# letting an agent restart ITSELF (e.g. to re-enumerate MCP tools after a deploy) and still
# get pinged back to continue, instead of dying silently.
cmd_restart_worker() { # $1=name [$2=note]
  local name="$1" note="${2:-}"
  sleep 1                                   # let the kill settle before relaunch (race-safe)
  cmd_start "$name" >/dev/null 2>&1
  [ -z "$note" ] && return 0
  wait_ready "$name" || log "restart $name: ready-wait timed out — sending note anyway"
  cmd_send "$name" "$note" >/dev/null 2>&1
  log "restart $name: wake-note delivered"
}

cmd_restart() { # $1=name [--then <note>]  (detached so it survives killing the calling session)
  local name="$1" note=""; shift || true
  [ "${1:-}" = "--then" ] && note="${2:-}"
  tmux_c kill-session -t "$(tgt "$name")" 2>/dev/null
  # Detached + SIGHUP-immune so it survives killing the calling session. `nohup … &` is
  # portable (macOS has no setsid). The note is passed as a single clean arg — no re-quoting,
  # so spaces / quotes / non-ASCII in the note survive intact.
  nohup "$SELF" _restart_worker "$name" "$note" </dev/null >/dev/null 2>&1 &
  echo "restarting $name${note:+ (will ping when ready)}"
}

cmd_ensure() { # one fork for the running set, then heal anything missing
  local running n
  running="$(tmux_c list-sessions -F '#{session_name}' 2>/dev/null)"
  while IFS= read -r n; do
    [ -z "$n" ] && continue
    grep -qxF "$n" <<<"$running" || cmd_start "$n"
  done < <(session_names)
}

cmd_daemon() {
  trap 'log "daemon stopping"; exit 0' TERM INT   # clean exit -> no restart thrash
  [ -x "$CLAUDE_BIN" ] || { log "claude not executable: $CLAUDE_BIN — daemon exiting"; \
    echo "claude bin invalid: $CLAUDE_BIN"; exit 0; }
  log "ccmux daemon up (rc=$RC_PREFIX interval=${ENSURE_INTERVAL}s)"
  while true; do
    cmd_ensure || log "ensure pass failed"      # one bad pass never kills the daemon
    sleep "$ENSURE_INTERVAL"
  done
}

# ── Read commands ───────────────────────────────────────────────────────────
cmd_list() {
  [ "${1:-}" = "--json" ] && { cmd_list_json; return; }
  local created now n c up model ctx state used
  created="$(tmux_c list-sessions -F '#{session_name} #{session_created}' 2>/dev/null)"
  now="$(date +%s)"
  printf '%-12s %-9s %-16s %-8s %-7s %-14s %s\n' SESSION MODEL CTX STATE UPTIME RC DIR
  while IFS= read -r n; do
    [ -z "$n" ] && continue
    c="$(awk -v s="$n" '$1==s{print $2}' <<<"$created")"
    model='-'; ctx='-'; state=stopped; up='-'
    if [ -n "$c" ]; then
      up="$(humanize $((now - c)))"
      IFS=$'\t' read -r model ctx state < <(pane_status "$n")
      # statusline gives the full window/% when present; else fall back to the
      # universal USED size from the transcript — size is known with or without a statusline.
      if [ "$ctx" = '-' ]; then
        used="$(session_used "$(session_dir "$n")" "$(session_uuid "$n")")"
        [ "${used:-0}" -gt 0 ] 2>/dev/null && ctx="$(fmt_tok "$used")"
      fi
    fi
    printf '%-12s %-9s %-16s %-8s %-7s %-14s %s\n' "$n" "$model" "$ctx" "$state" "$up" "$(rc_name "$n")" "$(session_dir "$n")"
  done < <(session_names)
}

cmd_list_json() {
  local created now n c up up_seconds model ctx state used uuid first=1 running created_at dir last_message
  created="$(tmux_c list-sessions -F '#{session_name} #{session_created}' 2>/dev/null)"
  now="$(date +%s)"
  printf '{"version":'
  json_string "$VERSION"
  printf ',"generatedAt":'
  json_string "$(date -u +%FT%TZ)"
  printf ',"rcPrefix":'
  json_string "$RC_PREFIX"
  printf ',"sessionsFile":'
  json_string "$SESSIONS_FILE"
  printf ',"sessions":['
  while IFS= read -r n; do
    [ -z "$n" ] && continue
    c="$(awk -v s="$n" '$1==s{print $2}' <<<"$created")"
    dir="$(session_dir "$n")"
    uuid="$(session_uuid "$n")"
    last_message="$(last_transcript_message_json "$dir" "$uuid")"
    model='-'; ctx='-'; state=stopped; up='-'; up_seconds=''; running=0; created_at=''
    if [ -n "$c" ]; then
      running=1
      up_seconds=$((now - c))
      up="$(humanize "$up_seconds")"
      created_at="$(date -u -r "$c" +%FT%TZ 2>/dev/null || date -u -d "@$c" +%FT%TZ 2>/dev/null || true)"
      IFS=$'\t' read -r model ctx state < <(pane_status "$n")
      if [ "$ctx" = '-' ]; then
        used="$(session_used "$dir" "$uuid")"
        [ "${used:-0}" -gt 0 ] 2>/dev/null && ctx="$(fmt_tok "$used")"
      fi
    fi
    [ "$first" = 1 ] && first=0 || printf ','
    printf '{"name":'
    json_string "$n"
    printf ',"dir":'
    json_string "$dir"
    printf ',"uuid":'
    json_string "$uuid"
    printf ',"rc":'
    json_string "$(rc_name "$n")"
    printf ',"running":'
    json_bool "$running"
    printf ',"state":'
    json_string "$state"
    printf ',"model":'
    json_nullable_string "$model"
    printf ',"context":'
    context_json "$ctx"
    printf ',"uptime":{"text":'
    json_nullable_string "$up"
    printf ',"seconds":'
    json_nullable_number "$up_seconds"
    printf '},"createdAt":'
    json_nullable_string "$created_at"
    printf ',"lastMessage":'
    printf '%s' "$last_message"
    printf '}'
  done < <(session_names)
  printf ']}'
  printf '\n'
}

cmd_send() { # $1=name $2..=keys (e.g. '/compact')
  local name="$1" p; shift
  p="$(pane "$name")"
  # Send the literal text, let readline drain it, THEN a separate Enter. Without the
  # gap, Enter can arrive before the text is buffered and the line goes empty/split.
  # `--` so payloads starting with '-' (e.g. a flag-like prompt) aren't parsed as options.
  tmux_c send-keys -t "$p" -l -- "$*" || { echo "send failed: $name not running?"; return 1; }
  sleep 0.15
  tmux_c send-keys -t "$p" Enter
  echo "sent to $name: $*"
}

cmd_logs() {
  local name="${1:-}" lines="${2:-100}" format="${3:-}"
  if [ "$lines" = "--json" ]; then lines=100; format="--json"; fi
  if [ "$format" = "--json" ]; then
    local text
    text="$(tmux_c capture-pane -t "$(pane "$name")" -p -S -"$lines")" || return 1
    printf '{"session":'
    json_string "$name"
    printf ',"capturedAt":'
    json_string "$(date -u +%FT%TZ)"
    printf ',"lines":%s,"text":' "$lines"
    json_string "$text"
    printf '}\n'
    return
  fi
  tmux_c capture-pane -t "$(pane "$name")" -p -S -"$lines"
}

cmd_transcript() {
  local name="${1:-}" format="" tail_count=200 cursor="" arg
  [ -n "$name" ] || { echo "usage: ccmux transcript <name> --json [--tail N] [--cursor LINE]"; return 1; }
  shift || true
  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --json) format="--json" ;;
      --tail)
        shift
        tail_count="${1:-}"
        ;;
      --cursor)
        shift
        cursor="${1:-}"
        ;;
      *)
        if [[ "$arg" =~ ^[0-9]+$ ]]; then tail_count="$arg"
        else echo "unknown transcript arg: $arg"; return 1
        fi
        ;;
    esac
    shift || true
  done
  [ "$format" = "--json" ] || { echo "usage: ccmux transcript <name> --json [--tail N] [--cursor LINE]"; return 1; }
  [[ "$tail_count" =~ ^[0-9]+$ ]] || tail_count=200
  [ "$tail_count" -gt 0 ] 2>/dev/null || tail_count=200
  [ "$tail_count" -le 1000 ] 2>/dev/null || tail_count=1000

  local dir uuid jf generated_at source_kind source_available source_error total_lines start_line messages mtime_ms
  dir="$(session_dir "$name")" || { echo "unknown session: $name"; return 1; }
  uuid="$(session_uuid "$name")"
  jf="$(hist_file "$dir" "$uuid")"
  generated_at="$(date -u +%FT%TZ)"
  source_kind=claude-jsonl
  source_available=1
  source_error=""
  total_lines=0
  start_line=1
  messages='[]'
  mtime_ms=''

  if ! _have jq >/dev/null; then
    source_kind=unavailable
    source_available=0
    source_error="jq missing"
  elif [ ! -f "$jf" ]; then
    source_kind=unavailable
    source_available=0
    source_error="transcript file not found"
  else
    total_lines="$(wc -l < "$jf" 2>/dev/null | tr -d '[:space:]')"
    [ "${total_lines:-0}" -ge 0 ] 2>/dev/null || total_lines=0
    if [[ "$cursor" =~ ^[0-9]+$ ]]; then
      start_line=$(( cursor + 1 ))
    else
      start_line=$(( total_lines > tail_count ? total_lines - tail_count + 1 : 1 ))
    fi
    [ "$start_line" -ge 1 ] 2>/dev/null || start_line=1
    messages="$(transcript_messages_json "$jf" "$start_line" 6000)"
    mtime_ms="$(file_mtime_ms "$jf")"
  fi

  printf '{"version":'
  json_string "$VERSION"
  printf ',"generatedAt":'
  json_string "$generated_at"
  printf ',"session":{"name":'
  json_string "$name"
  printf ',"uuid":'
  json_string "$uuid"
  printf ',"rc":'
  json_string "$(rc_name "$name")"
  printf ',"dir":'
  json_string "$dir"
  printf ',"machine":'
  json_string "$RC_PREFIX"
  printf '},"source":{"kind":'
  json_string "$source_kind"
  printf ',"path":'
  json_string "$jf"
  printf ',"available":'
  json_bool "$source_available"
  printf ',"error":'
  json_nullable_string "$source_error"
  printf '},"cursor":{"opaque":'
  [ "$source_available" = 1 ] && json_string "$total_lines" || printf 'null'
  printf ',"line":'
  [ "$source_available" = 1 ] && json_nullable_number "$total_lines" || printf 'null'
  printf ',"byteOffset":null,"mtimeMs":'
  json_nullable_number "$mtime_ms"
  printf '},"messages":'
  printf '%s' "$messages"
  printf '}\n'
}

cmd_doctor() {
  [ "${1:-}" = "--json" ] && { cmd_doctor_json; return; }
  echo "ccmux $VERSION"
  echo "self: $SELF"
  echo "config: $CONFIG_FILE"
  echo "sessions: $SESSIONS_FILE"
  echo "rc prefix: $RC_PREFIX"
  echo "boot label: $BOOT_LABEL"
  echo "claude: $CLAUDE_BIN ($(if [ -x "$CLAUDE_BIN" ]; then echo ok; else echo missing; fi))"
  echo "tmux: $TMUX_BIN ($(if [ -x "$TMUX_BIN" ] || command -v "$TMUX_BIN" >/dev/null 2>&1; then echo ok; else echo missing; fi))"
  echo "jq: $(command -v jq 2>/dev/null || echo missing)"
  case "$(uname)" in
    Darwin) launchctl list 2>/dev/null | grep -q "[[:space:]]$BOOT_LABEL$" && echo "daemon: active" || echo "daemon: inactive" ;;
    Linux)  systemctl is-active "$BOOT_LABEL" 2>/dev/null | awk '{print "daemon: "$0}' ;;
    *)      echo "daemon: unknown" ;;
  esac
}

cmd_doctor_json() {
  local os daemon_state tmux_ok claude_ok jq_path
  os="$(uname)"
  if [ -x "$CLAUDE_BIN" ]; then claude_ok=1; else claude_ok=0; fi
  if [ -x "$TMUX_BIN" ] || command -v "$TMUX_BIN" >/dev/null 2>&1; then tmux_ok=1; else tmux_ok=0; fi
  jq_path="$(command -v jq 2>/dev/null || true)"
  daemon_state="unknown"
  case "$os" in
    Darwin) launchctl list 2>/dev/null | grep -q "[[:space:]]$BOOT_LABEL$" && daemon_state=active || daemon_state=inactive ;;
    Linux)  daemon_state="$(systemctl is-active "$BOOT_LABEL" 2>/dev/null || true)" ;;
  esac
  printf '{"version":'
  json_string "$VERSION"
  printf ',"generatedAt":'
  json_string "$(date -u +%FT%TZ)"
  printf ',"os":'
  json_string "$os"
  printf ',"self":'
  json_string "$SELF"
  printf ',"configFile":'
  json_string "$CONFIG_FILE"
  printf ',"sessionsFile":'
  json_string "$SESSIONS_FILE"
  printf ',"rcPrefix":'
  json_string "$RC_PREFIX"
  printf ',"bootLabel":'
  json_string "$BOOT_LABEL"
  printf ',"logFile":'
  json_string "$LOG_FILE"
  printf ',"claudeBin":'
  json_string "$CLAUDE_BIN"
  printf ',"tmuxBin":'
  json_string "$TMUX_BIN"
  printf ',"deps":{"claude":'
  json_bool "$claude_ok"
  printf ',"tmux":'
  json_bool "$tmux_ok"
  printf ',"jq":'
  json_bool "$(if [ -n "$jq_path" ]; then echo 1; else echo 0; fi)"
  printf '},"daemon":{"manager":'
  case "$os" in
    Darwin) json_string launchd ;;
    Linux)  json_string systemd ;;
    *)      printf 'null' ;;
  esac
  printf ',"state":'
  json_string "$daemon_state"
  printf '}}\n'
}

# ── Registry ────────────────────────────────────────────────────────────────
cmd_new() { # $1=name $2=dir
  local name="${1:-}" dir="${2:-}" uuid
  { [ -z "$name" ] || [ -z "$dir" ]; } && { echo "usage: ccmux new <name> <dir>"; return 1; }
  case "$name" in *['|'' ''#']*) echo "name: no '|', space, or '#'"; return 1;; esac
  case "$dir"  in /*) ;; *) echo "dir must be absolute: $dir"; return 1;; esac
  [ -d "$dir" ] || { echo "dir not found: $dir"; return 1; }
  session_dir "$name" >/dev/null 2>&1 && { echo "'$name' already registered"; return 1; }
  uuid="$(uuidgen 2>/dev/null | tr 'A-Z' 'a-z')" || uuid="$(cat /proc/sys/kernel/random/uuid)"
  mkdir -p "$(dirname "$SESSIONS_FILE")"
  printf '%s|%s|%s\n' "$name" "$dir" "$uuid" >> "$SESSIONS_FILE"
  echo "added: $name|$dir|$uuid"
  cmd_start "$name"
}

cmd_rm() { # $1=name [$2=--force]
  local name="${1:-}"
  [ -z "$name" ] && { echo "usage: ccmux rm <name>"; return 1; }
  refuse_self rm "$name" "${2:-}" && return 1
  session_dir "$name" >/dev/null 2>&1 || { echo "'$name' not registered"; return 1; }
  cmd_stop "$name" --force
  local tmp; tmp="$(mktemp)"
  awk -F'|' -v n="$name" '$1!=n' "$SESSIONS_FILE" > "$tmp" && mv "$tmp" "$SESSIONS_FILE"
  echo "removed $name (jsonl history kept on disk)"
}

# ── Boot install (one daemon unit; systemd on Linux, launchd on macOS) ───────
# Best-effort: jq powers the universal context-SIZE in `list` (used tokens from the
# transcript, shown even with no statusline). Missing jq is non-fatal — CTX just falls
# back to whatever the statusline surfaces, or '-'.
ensure_deps() {
  _have jq >/dev/null && return 0
  echo "ccmux: installing jq (for context size in list)…"
  if   _have brew    >/dev/null; then brew install jq
  elif _have apt-get >/dev/null; then sudo apt-get update -qq && sudo apt-get install -y jq
  elif _have dnf     >/dev/null; then sudo dnf install -y jq
  elif _have yum     >/dev/null; then sudo yum install -y jq
  elif _have pacman  >/dev/null; then sudo pacman -S --noconfirm jq
  elif _have apk     >/dev/null; then sudo apk add jq
  else echo "ccmux: no known package manager — install jq manually for context size."; fi
}
cmd_install() {
  mkdir -p "$(dirname "$SESSIONS_FILE")" "$(dirname "$CONFIG_FILE")"
  [ -f "$SESSIONS_FILE" ] || printf '# ccmux sessions — name|dir|uuid (add via `ccmux new`)\n' > "$SESSIONS_FILE"
  ensure_deps
  case "$(uname)" in
    Darwin) _install_launchd ;;
    Linux)  _install_systemd ;;
    *) echo "unsupported OS: $(uname)"; return 1 ;;
  esac
}
_install_launchd() {
  local plist="$HOME/Library/LaunchAgents/$BOOT_LABEL.plist"
  mkdir -p "$(dirname "$plist")"
  cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$BOOT_LABEL</string>
  <key>ProgramArguments</key><array><string>$SELF</string><string>daemon</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$LOG_FILE</string>
  <key>StandardErrorPath</key><string>$LOG_FILE</string>
  <key>EnvironmentVariables</key><dict><key>HOME</key><string>$HOME</string></dict>
</dict></plist>
PLIST
  launchctl bootout "gui/$(id -u)/$BOOT_LABEL" 2>/dev/null
  launchctl bootstrap "gui/$(id -u)" "$plist"
  echo "installed launchd $BOOT_LABEL -> $plist"
}
_install_systemd() {
  local unit="/etc/systemd/system/$BOOT_LABEL.service"
  cat > "$unit" <<UNIT
[Unit]
Description=ccmux — persistent Claude Code tmux sessions
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=$HOME
ExecStart=$SELF daemon
Restart=on-failure
RestartSec=3
# Only kill the daemon's own pid on stop/restart — leave the tmux server (and every live
# session it hosts) running, so bouncing the daemon never drops a conversation. Matches
# macOS, where the tmux server detaches from the launchd job on its own.
KillMode=process

[Install]
WantedBy=multi-user.target
UNIT
  systemctl daemon-reload
  systemctl enable --now "$BOOT_LABEL"
  echo "installed systemd $BOOT_LABEL"
}
cmd_uninstall() {
  case "$(uname)" in
    Darwin) launchctl bootout "gui/$(id -u)/$BOOT_LABEL" 2>/dev/null
            rm -f "$HOME/Library/LaunchAgents/$BOOT_LABEL.plist" ;;
    Linux)  systemctl disable --now "$BOOT_LABEL" 2>/dev/null
            rm -f "/etc/systemd/system/$BOOT_LABEL.service"; systemctl daemon-reload ;;
  esac
  echo "uninstalled $BOOT_LABEL (sessions file + jsonl history kept)"
}

# ── Help ────────────────────────────────────────────────────────────────────
cmd_help() {
  cat <<HELP
ccmux $VERSION — Cloud Code MUX
persistent, self-healing Claude Code sessions in tmux · deterministic resume

  ccmux list [--json]               sessions + status / uptime
  ccmux doctor [--json]             local install + daemon diagnostics
  ccmux new <name> <dir>            register + start a session (pins a uuid)
  ccmux rm <name> [--force]         stop + unregister (jsonl history kept)
  ccmux start|stop|restart <name>   lifecycle  (stop/rm of self needs --force)
  ccmux restart <name> --then "<note>"   restart, then type <note> once the session is ready
  ccmux send <name> <keys...>       type into a session (text or /slash)
  ccmux logs <name> [lines] [--json] print a session's pane
  ccmux transcript <name> --json [--tail N] [--cursor LINE]
                                      structured Claude chat transcript
  ccmux install | uninstall         boot unit for the daemon (systemd/launchd)
  ccmux daemon | ensure             run / single-pass the heal supervisor
  ccmux help | version

sessions persist across logout & reboot; one daemon heals them every ${ENSURE_INTERVAL}s.
attach by hand: tmux attach -t <name>
config: $CONFIG_FILE   data: $SESSIONS_FILE
HELP
}

# ── Dispatch ────────────────────────────────────────────────────────────────
case "${1:-help}" in
  _run)            shift; cmd_run "$@" ;;
  _restart_worker) cmd_restart_worker "${2:-}" "${3:-}" ;;
  start)           cmd_start "${2:-}" ;;
  stop)            cmd_stop "${2:-}" "${3:-}" ;;
  restart)         shift; cmd_restart "$@" ;;
  ensure)          cmd_ensure ;;
  daemon)          cmd_daemon ;;
  list|ls|l)       shift; cmd_list "$@" ;;
  doctor)          cmd_doctor "${2:-}" ;;
  new)             cmd_new "${2:-}" "${3:-}" ;;
  rm|remove)       cmd_rm "${2:-}" "${3:-}" ;;
  send)            shift; cmd_send "$@" ;;
  logs)            cmd_logs "${2:-}" "${3:-}" "${4:-}" ;;
  transcript)      shift; cmd_transcript "$@" ;;
  install)         cmd_install ;;
  uninstall)       cmd_uninstall ;;
  help|-h|--help)  cmd_help ;;
  version|-v|--version) echo "ccmux $VERSION" ;;
  *) cmd_help; exit 1 ;;
esac
